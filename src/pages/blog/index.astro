---
import Layout from "@components/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const parseDateValue = (entry: CollectionEntry<'posts'>) => {
  const candidates = [entry.data.publishedAt, entry.data.updatedAt];
  for (const candidate of candidates) {
    if (!candidate) continue;
    const parsed = new Date(candidate);
    if (!Number.isNaN(parsed.getTime())) {
      return parsed.getTime();
    }
  }
  const weekPlan = typeof entry.data.week_plan === 'string' ? entry.data.week_plan : '';
  const weekMatch = weekPlan.match(/^(\d{4})w(\d{2})$/i);
  if (weekMatch) {
    const [, year, week] = weekMatch;
    const dayOfYear = (parseInt(week, 10) - 1) * 7;
    const base = new Date(Number(year), 0, 1);
    base.setDate(base.getDate() + dayOfYear);
    return base.getTime();
  }
  return 0;
};

const resolveDateLabel = (entry: CollectionEntry<'posts'>) => {
  const sources = [entry.data.publishedAt, entry.data.updatedAt];
  for (const source of sources) {
    if (!source) continue;
    const parsed = new Date(source);
    if (!Number.isNaN(parsed.getTime())) {
      return parsed.toLocaleDateString('vi-VN');
    }
  }
  const weekPlan = typeof entry.data.week_plan === 'string' ? entry.data.week_plan : '';
  const weekMatch = weekPlan.match(/^(\d{4})w(\d{2})$/i);
  if (weekMatch) {
    const [, year, week] = weekMatch;
    return `Tuần ${parseInt(week, 10)} / ${year}`;
  }
  return 'Đang cập nhật';
};

const pillarMap: Record<string, { label: string; class: string }> = {
  'tong-quan-quy-hoach': { label: 'Tổng quan', class: 'tag--tong-quan' },
  'phan-tich-khu-vuc': { label: 'Phân tích khu vực', class: 'tag--phan-tich' },
  'phap-ly-va-rui-ro': { label: 'Pháp lý', class: 'tag--phap-ly' },
  'tiem-nang-va-co-hoi': { label: 'Tiềm năng', class: 'tag--tiem-nang' },
};

const accentMap: Record<string, string> = {
  'tong-quan-quy-hoach': 'var(--tag-tong-quan)',
  'phan-tich-khu-vuc': 'var(--tag-phan-tich)',
  'phap-ly-va-rui-ro': 'var(--tag-phap-ly)',
  'tiem-nang-va-co-hoi': 'var(--tag-tiem-nang)',
};

const resolveExcerpt = (entry: CollectionEntry<'posts'>) =>
  entry.data.excerpt ?? entry.data.description ?? '';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => parseDateValue(b) - parseDateValue(a));
const baseEnv = import.meta.env.BASE_URL ?? '/';
const basePath = baseEnv.endsWith('/') ? baseEnv.slice(0, -1) : baseEnv;

const [featured, ...rest] = posts;
const featuredPillar = pillarMap[featured?.data.pillar] ?? { label: 'Bài viết', class: 'tag--tiem-nang' };
---
<Layout title="Bài viết Hòa Lạc" description="Thư viện bài phân tích thị trường đất Hòa Lạc">
  <section class="blog-page">
    <div class="blog-page__header">
      <h1>Bản tin thị trường</h1>
      <p>Phân tích thực địa, dữ liệu quy hoạch và góc nhìn chiến lược dành cho nhà đầu tư và gia đình đang sàng đất Hòa Lạc.</p>
    </div>

    {featured && (
      <a href={`${basePath}/blog/${featured.slug}`} class="featured" style={featured.data.thumbnail ? `--featured-bg: url(${basePath}${featured.data.thumbnail})` : ''}>
        <span class="featured__label">Bài nổi bật</span>
        <div class="featured__meta">
          <span class="featured__tag">{featuredPillar.label}</span>
          <span class="featured__date">{resolveDateLabel(featured)}</span>
        </div>
        <h2 class="featured__title">{featured.data.title}</h2>
        <p class="featured__desc">{resolveExcerpt(featured)}</p>
        <div class="featured__arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <>
        <p class="section-label">Tất cả bài viết</p>
        <div class="article-grid">
          {rest.map((post) => {
            const pillar = pillarMap[post.data.pillar] ?? { label: 'Bài viết', class: 'tag--tiem-nang' };
            const accent = accentMap[post.data.pillar] ?? 'var(--accent)';
            return (
              <a href={`${basePath}/blog/${post.slug}`} class="article-card" style={`--card-accent: ${accent}`}>
                <div class="article-card__meta">
                  <span class={`blog-tag ${pillar.class}`}>{pillar.label}</span>
                  <span class="article-card__date">{resolveDateLabel(post)}</span>
                </div>
                <h3 class="article-card__title">{post.data.title}</h3>
                <p class="article-card__desc">{resolveExcerpt(post)}</p>
              </a>
            );
          })}
        </div>
      </>
    )}
  </section>
</Layout>

<style>
  :root {
    --tag-tong-quan: #2563eb;
    --tag-phan-tich: #059669;
    --tag-phap-ly: #d97706;
    --tag-tiem-nang: #d44809;
  }

  .blog-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .blog-page__header {
    margin-bottom: 3rem;
  }
  .blog-page__header h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 0.6rem;
  }
  .blog-page__header p {
    color: var(--muted);
    font-size: 0.92rem;
    max-width: 560px;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Featured ── */
  .featured {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    margin-bottom: 3rem;
    background: linear-gradient(135deg, #1b1b1b 0%, #2d1a0e 40%, #3d1f08 70%, var(--accent-dark) 100%);
    background-image: var(--featured-bg, none), linear-gradient(135deg, #1b1b1b 0%, #2d1a0e 40%, #3d1f08 70%, var(--accent-dark) 100%);
    background-size: cover, cover;
    background-position: center, center;
    min-height: 340px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.5rem 3rem;
    transition: transform 300ms ease, box-shadow 300ms ease;
    cursor: pointer;
    text-decoration: none;
    color: #fff;
  }
  .featured::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.1) 100%);
    pointer-events: none;
  }
  .featured::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(212,72,9,0.12) 0%, transparent 70%);
    border-radius: 50%;
    transform: translate(30%, -30%);
    pointer-events: none;
  }
  .featured:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  }

  .featured__label {
    position: relative;
    z-index: 1;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.5rem;
  }
  .featured__meta {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .featured__tag {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    padding: 0.3rem 0.7rem;
    border-radius: 3px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
  }
  .featured__date {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    font-weight: 500;
  }
  .featured__title {
    position: relative;
    z-index: 1;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 0.8rem;
    max-width: 700px;
  }
  .featured__desc {
    position: relative;
    z-index: 1;
    font-size: 0.92rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.7);
    max-width: 600px;
    margin: 0;
  }
  .featured__arrow {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 200ms ease, transform 200ms ease;
    z-index: 1;
  }
  .featured:hover .featured__arrow {
    background: rgba(212,72,9,0.6);
    transform: translateX(4px);
  }
  .featured__arrow svg {
    width: 18px;
    height: 18px;
    color: rgba(255,255,255,0.7);
  }

  /* ── Section label ── */
  .section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: var(--muted);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--text);
    display: inline-block;
  }

  /* ── Grid ── */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border-radius: 0.75rem;
    background: #fff;
    border: 1px solid rgba(27,27,27,0.08);
    text-decoration: none;
    color: var(--text);
    transition: transform 250ms ease, box-shadow 250ms ease, border-color 250ms ease;
    position: relative;
    overflow: hidden;
  }
  .article-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--card-accent, var(--accent));
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    border-color: rgba(27,27,27,0.12);
  }
  .article-card:hover::before {
    opacity: 1;
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .article-card__date {
    font-size: 0.82rem;
    color: var(--muted);
  }
  .article-card__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card__desc {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: auto 0 0;
  }

  /* ── Tags ── */
  .blog-tag {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    padding: 0.25rem 0.55rem;
    border-radius: 3px;
    white-space: nowrap;
  }
  .tag--tong-quan {
    background: rgba(37,99,235,0.08);
    color: var(--tag-tong-quan);
  }
  .tag--phan-tich {
    background: rgba(5,150,105,0.08);
    color: var(--tag-phan-tich);
  }
  .tag--phap-ly {
    background: rgba(217,119,6,0.08);
    color: var(--tag-phap-ly);
  }
  .tag--tiem-nang {
    background: rgba(212,72,9,0.08);
    color: var(--tag-tiem-nang);
  }

  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .featured { animation: fadeUp 600ms ease-out both; }
  .article-card:nth-child(1) { animation: fadeUp 500ms ease-out 100ms both; }
  .article-card:nth-child(2) { animation: fadeUp 500ms ease-out 180ms both; }
  .article-card:nth-child(3) { animation: fadeUp 500ms ease-out 260ms both; }
  .article-card:nth-child(4) { animation: fadeUp 500ms ease-out 340ms both; }
  .article-card:nth-child(5) { animation: fadeUp 500ms ease-out 420ms both; }
  .article-card:nth-child(6) { animation: fadeUp 500ms ease-out 500ms both; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .blog-page {
      padding: 2rem 1.25rem 4rem;
    }
    .featured {
      min-height: 280px;
      padding: 2rem 1.5rem;
      border-radius: 0.75rem;
    }
    .featured__title {
      font-size: 1.4rem;
    }
    .featured__arrow {
      display: none;
    }
    .article-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .article-card {
      padding: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .featured {
      min-height: 240px;
      padding: 1.5rem 1.25rem;
    }
    .featured__title {
      font-size: 1.25rem;
    }
    .featured__desc {
      font-size: 0.85rem;
    }
  }
</style>
