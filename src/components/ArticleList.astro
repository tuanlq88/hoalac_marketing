---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts = [] } = Astro.props;

const getTags = (entry: CollectionEntry<'posts'>) =>
  Array.isArray(entry.data.tags) ? entry.data.tags : [];

const resolveDateLabel = (entry: CollectionEntry<'posts'>) => {
  const sources = [entry.data.publishedAt, entry.data.updatedAt];
  for (const source of sources) {
    if (!source) continue;
    const parsed = new Date(source);
    if (!Number.isNaN(parsed.getTime())) {
      return parsed.toLocaleDateString('vi-VN');
    }
  }
  const weekPlan = typeof entry.data.week_plan === 'string' ? entry.data.week_plan : '';
  const weekMatch = weekPlan.match(/^(\d{4})w(\d{2})$/i);
  if (weekMatch) {
    const [, year, week] = weekMatch;
    return `Tuần ${parseInt(week, 10)} / ${year}`;
  }
  return 'Đang cập nhật';
};

const resolveExcerpt = (entry: CollectionEntry<'posts'>) =>
  entry.data.excerpt ?? entry.data.description ?? '';

const filterPublicTags = (tags: string[]) => tags.filter((tag) => !tag.startsWith('lead_'));
const baseEnv = import.meta.env.BASE_URL ?? '/';
const basePath = baseEnv.endsWith('/') ? baseEnv.slice(0, -1) : baseEnv;
const blogHref = `${basePath}/blog`;

// Pillar → Gradient mapping
const pillarGradients: Record<string, string> = {
  'tong-quan-quy-hoach': 'linear-gradient(135deg, #0f172a, #1e3a5f)',
  'phan-tich-khu-vuc': 'linear-gradient(135deg, #0c4a6e, #164e63)',
  'phap-ly-va-rui-ro': 'linear-gradient(135deg, #7c2d12, #9a3412)',
  'tiem-nang-va-co-hoi': 'linear-gradient(135deg, #14532d, #166534)',
};

// Pillar → Display name mapping
const pillarNames: Record<string, string> = {
  'tong-quan-quy-hoach': 'Tổng quan & Quy hoạch',
  'phan-tich-khu-vuc': 'Phân tích khu vực',
  'phap-ly-va-rui-ro': 'Pháp lý & Rủi ro',
  'tiem-nang-va-co-hoi': 'Tiềm năng & Cơ hội',
};

// Persona → Display name mapping
const personaNames: Record<string, string> = {
  'mua-de-o': 'Mua để ở',
  'mua-dau-tu-dai-han': 'Đầu tư dài hạn',
  'kinh-doanh-dong-tien': 'Kinh doanh dòng tiền',
};

// Persona → Dot color mapping
const personaDotColors: Record<string, string> = {
  'mua-de-o': '#10b981',
  'mua-dau-tu-dai-han': '#3b82f6',
  'kinh-doanh-dong-tien': '#f59e0b',
};

const getPillarGradient = (pillar?: string) => {
  return pillar && pillarGradients[pillar]
    ? pillarGradients[pillar]
    : 'linear-gradient(135deg, #0f172a, #334155)';
};

const getPillarName = (pillar?: string) => {
  return pillar && pillarNames[pillar] ? pillarNames[pillar] : 'Bài viết';
};

const getPersonaName = (persona?: string) => {
  return persona && personaNames[persona] ? personaNames[persona] : '';
};

const getPersonaDotColor = (persona?: string) => {
  return persona && personaDotColors[persona] ? personaDotColors[persona] : '#64748b';
};
---
<section class="section-shell section-shell--alt article-list" data-article-shelf>
  <div class="shell-inner">
    <div class="article-list__head">
      <div>
        <h2>Snapshot thị trường</h2>
        <p data-article-context>Chưa chọn ưu tiên cụ thể.</p>
      </div>
      <a class="button button--ghost" href={blogHref}>Xem tất cả bài</a>
    </div>
    <div class="article-list__grid" id="article-grid">
      <div class="skeleton-card" aria-hidden="true">
        <div class="skeleton skeleton--tag" style="width: 5rem;"></div>
        <div class="skeleton skeleton--title" style="width: 80%; margin-top: 0.8rem;"></div>
        <div class="skeleton skeleton--title" style="width: 55%;"></div>
        <div class="skeleton skeleton--text" style="width: 100%; margin-top: 0.5rem;"></div>
        <div class="skeleton skeleton--text" style="width: 90%;"></div>
        <div class="skeleton skeleton--text" style="width: 60%;"></div>
      </div>
      <div class="skeleton-card" aria-hidden="true">
        <div class="skeleton skeleton--tag" style="width: 4.5rem;"></div>
        <div class="skeleton skeleton--title" style="width: 70%; margin-top: 0.8rem;"></div>
        <div class="skeleton skeleton--title" style="width: 50%;"></div>
        <div class="skeleton skeleton--text" style="width: 95%; margin-top: 0.5rem;"></div>
        <div class="skeleton skeleton--text" style="width: 85%;"></div>
        <div class="skeleton skeleton--text" style="width: 45%;"></div>
      </div>
      <div class="skeleton-card" aria-hidden="true">
        <div class="skeleton skeleton--tag" style="width: 5.5rem;"></div>
        <div class="skeleton skeleton--title" style="width: 75%; margin-top: 0.8rem;"></div>
        <div class="skeleton skeleton--title" style="width: 60%;"></div>
        <div class="skeleton skeleton--text" style="width: 100%; margin-top: 0.5rem;"></div>
        <div class="skeleton skeleton--text" style="width: 80%;"></div>
        <div class="skeleton skeleton--text" style="width: 50%;"></div>
      </div>
    {posts.map((post) => {
      const rawTags = getTags(post);
      const publicTags = filterPublicTags(rawTags);
      const articleHref = `${basePath}/blog/${post.slug}`;
      const pillar = post.data.pillar;
      const persona = post.data.target_persona;
      const gradient = getPillarGradient(pillar);
      const pillarDisplayName = getPillarName(pillar);
      const personaDisplayName = getPersonaName(persona);
      const personaDotColor = getPersonaDotColor(persona);

      return (
        <a
          href={articleHref}
          class="article-card"
          data-article-tags={publicTags.join(',')}
        >
          <div class="article-card__thumb" style={`background: ${gradient};`}>
            <span class="article-card__pillar-tag">{pillarDisplayName}</span>
            <h3 class="article-card__thumb-title">{post.data.title}</h3>
          </div>
          <div class="article-card__body">
            <p class="article-card__excerpt">{resolveExcerpt(post)}</p>
            <p class="article-card__status" data-personalized-badge>
              Khớp với ưu tiên của bạn
            </p>
            <div class="article-card__footer">
              <span class="article-card__date">{resolveDateLabel(post)}</span>
              {personaDisplayName && (
                <span class="article-card__persona">
                  <span class="article-card__persona-dot" style={`background: ${personaDotColor};`}></span>
                  {personaDisplayName}
                </span>
              )}
            </div>
          </div>
        </a>
      );
    })}
    </div>
  </div>
</section>

<style>
  .article-list__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .article-list__head p {
    margin: 0.25rem 0 0;
    color: var(--muted);
    font-weight: 600;
  }
  .article-list__grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .article-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 15px 45px rgba(0, 0, 0, 0.05);
    transition: transform 200ms ease, box-shadow 200ms ease;
    text-decoration: none;
    color: inherit;
    display: block;
    overflow: hidden;
  }
  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08);
  }
  .article-card[data-highlight="true"] {
    box-shadow: 0 25px 60px rgba(212, 72, 9, 0.18);
    border: 1px solid rgba(212, 72, 9, 0.35);
    transform: translateY(-4px);
  }
  .article-card[data-highlight="true"] [data-personalized-badge] {
    display: block !important;
  }
  .article-card__thumb {
    height: 170px;
    display: flex;
    align-items: flex-end;
    padding: 20px;
    position: relative;
    overflow: hidden;
  }
  .article-card__thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%);
    z-index: 0;
  }
  .article-card__pillar-tag {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 1;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .article-card__thumb-title {
    position: relative;
    z-index: 1;
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin: 0;
  }
  .article-card__body {
    padding: 20px;
  }
  .article-card__excerpt {
    font-size: 14px;
    color: #475569;
    line-height: 1.65;
    margin: 0 0 16px 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card__status {
    margin: 0 0 12px 0;
    color: var(--accent-dark);
    display: none;
    font-size: 13px;
    font-weight: 600;
  }
  .article-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid #f1f5f9;
  }
  .article-card__date {
    font-size: 12px;
    color: #94a3b8;
    font-weight: 600;
  }
  .article-card__persona {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: #f8fafc;
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 11px;
    color: #64748b;
    font-weight: 500;
    border: 1px solid #f1f5f9;
  }
  .article-card__persona-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  @media (max-width: 768px) {
    .article-list {
      padding-left: clamp(1.5rem, 6vw, 2.5rem);
      padding-right: clamp(1.5rem, 6vw, 2.5rem);
      margin-left: clamp(0.75rem, 4vw, 1.5rem);
      margin-right: clamp(0.75rem, 4vw, 1.5rem);
    }
  }
  @media (max-width: 480px) {
    .article-list {
      margin-left: 0.65rem;
      margin-right: 0.65rem;
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
  }
</style>

<script type="module">
  const PREFERENCE_STORAGE_KEY = 'hoaLacLeadPrefs';

  const loadLeadPreferences = () => {
    try {
      if (typeof window === 'undefined' || !window.sessionStorage) return null;
      const raw = window.sessionStorage.getItem(PREFERENCE_STORAGE_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      return {
        intent: typeof parsed?.intent === 'string' ? parsed.intent : '',
        areas: Array.isArray(parsed?.areas) ? parsed.areas : []
      };
    } catch (error) {
      console.warn('Không đọc được tùy chọn lead đã lưu.', error);
      return null;
    }
  };

  const shelf = document.querySelector('[data-article-shelf]');
  if (!shelf) {
    console.warn('Article shelf not found.');
  } else {
    const contextLine = shelf.querySelector('[data-article-context]');
    const cards = shelf.querySelectorAll('.article-card');

    const intentToKeywords = {
      o_thuc: ['ở thật', 'an cư', 'pháp lý'],
      dau_tu_trung_han: ['đầu tư', 'room tài chính', 'lợi nhuận'],
      luot_song: ['thanh khoản', 'sóng']
    };

    const areaKeywords = {
      'ĐHQG': ['ĐHQG', 'Đại học Quốc gia'],
      'khu CNC': ['CNC', 'công nghệ cao'],
      'Bình Yên': ['Bình Yên', 'Thạch Hòa'],
      'Tiến Xuân': ['Tiến Xuân', 'Yên Bình']
    };

    const highlightArticles = ({ intent, areas }) => {
      cards.forEach((card) => {
        card.removeAttribute('data-highlight');
      });

      if (!intent && (!areas || areas.length === 0)) {
        if (contextLine) contextLine.textContent = 'Chưa chọn ưu tiên cụ thể.';
        return;
      }

      const hasAreas = Array.isArray(areas) && areas.length > 0;

      const keywords = new Set();
      if (intent && intentToKeywords[intent]) {
        intentToKeywords[intent].forEach((word) => keywords.add(word));
      }
      if (hasAreas) {
        areas.forEach((areaLabel) => {
          Object.entries(areaKeywords).forEach(([key, values]) => {
            if (areaLabel.toLowerCase().includes(key.toLowerCase())) {
              values.forEach((word) => keywords.add(word));
            }
          });
        });
      }

      const matched = [];
      cards.forEach((card) => {
        const tagString = card.dataset.articleTags ?? '';
        const tagList = tagString.split(',').map((tag) => tag.trim().toLowerCase());
        const hasMatch = Array.from(keywords).some((word) =>
          tagList.some((tag) => tag.includes(word.toLowerCase()))
        );
        if (hasMatch) {
          card.setAttribute('data-highlight', 'true');
          matched.push(card);
        }
      });

      if (contextLine) {
        if (matched.length > 0) {
          const intentLabel = intent
            ? intent === 'o_thuc'
              ? 'an cư'
              : intent === 'dau_tu_trung_han'
                ? 'đầu tư'
                : 'sóng'
            : 'khu vực đã chọn';
          contextLine.textContent = `Đang ưu tiên ${intentLabel}, ${matched.length} bài viết khớp.`;
        } else {
          contextLine.textContent = 'Chưa tìm thấy bài nào khớp, xem tất cả bên dưới.';
        }
      }
    };

    let currentIntent = '';
    let currentAreas = [];

    window.addEventListener('lead-intent-change', (event) => {
      currentIntent = event?.detail?.intent ?? '';
      highlightArticles({ intent: currentIntent, areas: currentAreas });
    });

    window.addEventListener('lead-areas-change', (event) => {
      currentAreas = event?.detail?.areas ?? [];
      highlightArticles({ intent: currentIntent, areas: currentAreas });
    });

    const storedPrefs = loadLeadPreferences();
    if (storedPrefs) {
      currentIntent = storedPrefs.intent ?? '';
      currentAreas = storedPrefs.areas ?? [];
      if (currentIntent || currentAreas.length > 0) {
        highlightArticles({ intent: currentIntent, areas: currentAreas });
      }
    }
  }

  // Hide skeleton cards once fonts are ready
  const grid = document.getElementById('article-grid');
  if (grid) {
    if (document.fonts?.ready) {
      document.fonts.ready.then(() => grid.classList.add('is-loaded'));
    } else {
      grid.classList.add('is-loaded');
    }
  }
</script>
