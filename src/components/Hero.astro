---
const {
  title = "Góc nhìn quy hoạch Hòa Lạc — tầm nhìn đa chiều",
} = Astro.props;

const baseEnv = import.meta.env.BASE_URL ?? '/';
const basePath = baseEnv.endsWith('/') ? baseEnv.slice(0, -1) : baseEnv;
const blogHref = `${basePath}/blog`;
const heroImagePath = `${basePath}/images/hero-hoalac.png`;
---

<section class="hero" data-hero>
  <div class="hero__bg" style={`background-image: url('${heroImagePath}');`}></div>
  <div class="hero__overlay"></div>

  <div class="hero__inner">
    <!-- LEFT COLUMN -->
    <div class="hero__left">
      <div class="hero__eyebrow">
        <span class="hero__eyebrow-dot"></span>
        Dữ liệu quy hoạch chính thức
      </div>

      <h1 class="hero__title" set:html={title.replace(/Hòa Lạc/g, '<em>Hòa Lạc</em>')}></h1>

      <p class="hero__subtitle">
        Dữ liệu từ 6 quyết định quy hoạch đã được phê duyệt, phân tích theo từng phân khu
        — để anh/chị tự đánh giá trước khi gặp môi giới.
      </p>

      <div class="hero__cta-group">
        <a href="#lead-form" class="hero__cta hero__cta--primary" data-personalized-cta>
          Nhận phân tích cá nhân
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href={blogHref} class="hero__cta hero__cta--ghost">Đọc bài phân tích</a>
      </div>

      <div class="hero__stats">
        <div class="hero__stat">
          <div class="hero__stat-value hero__stat-value--gold">6</div>
          <div class="hero__stat-label">Phân khu đô thị</div>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <div class="hero__stat-value">508K</div>
          <div class="hero__stat-label">Dân số quy hoạch</div>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <div class="hero__stat-value">22</div>
          <div class="hero__stat-label">Ga Metro số 5</div>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <div class="hero__stat-value hero__stat-value--green">6</div>
          <div class="hero__stat-label">Văn bản QĐ gốc</div>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="hero__right">
      <!-- Featured article card -->
      <div class="hero__featured">
        <span class="hero__featured-tag">Bài mới nhất</span>
        <h3 class="hero__featured-title">Hạ tầng trọng điểm HL4: 5 yếu tố định hình trung tâm Hòa Lạc</h3>
        <p class="hero__featured-excerpt">Y tế vùng 120 ha, ga S18-S19, 3 trục giao thông quốc gia, quỹ NOXH 157 ha — phân tích từ QĐ 5105.</p>
        <a href={`${basePath}/blog/ha-tang-trong-diem-hl4`} class="hero__featured-link">
          Đọc bài phân tích
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <!-- Mini area cards -->
      <div class="hero__areas">
        <div class="hero__area-card">
          <div class="hero__area-name">HL3</div>
          <div class="hero__area-detail">1.004 ha · 48K người</div>
          <div class="hero__area-highlight">Sinh thái + ĐHQG</div>
        </div>
        <div class="hero__area-card hero__area-card--active">
          <div class="hero__area-name">HL4</div>
          <div class="hero__area-detail">1.880 ha · 145K người</div>
          <div class="hero__area-highlight">Trung tâm đô thị</div>
        </div>
        <div class="hero__area-card">
          <div class="hero__area-name">HL5</div>
          <div class="hero__area-detail">1.110 ha · 75K người</div>
          <div class="hero__area-highlight">Giải trí + nghỉ dưỡng</div>
        </div>
        <div class="hero__area-card">
          <div class="hero__area-name">HL6</div>
          <div class="hero__area-detail">700 ha · 77K người</div>
          <div class="hero__area-highlight">Cửa ngõ phía Nam</div>
        </div>
      </div>
    </div>
  </div>

  <div class="hero__source">Hình: Quy hoạch đô thị Hòa Lạc đến 2030 · QĐ 705/QĐ-TTg</div>
</section>

<style>
  /* ========== HERO — high specificity to override global.css ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 0;
    margin: 0;
    background: #0f172a;
    border-radius: 0;
    box-shadow: none;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-position: center 30%;
    background-size: cover;
    background-repeat: no-repeat;
    filter: brightness(0.45) saturate(1.2);
    z-index: 0;
    transform: scale(1.05);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.85) 0%, rgba(15, 23, 42, 0.4) 60%, transparent 100%),
      linear-gradient(to top, rgba(15, 23, 42, 0.9) 0%, transparent 40%);
    z-index: 1;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px clamp(1.5rem, 4vw, 3rem) 60px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 48px;
    align-items: end;
  }

  /* ========== LEFT COLUMN ========== */
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(212, 72, 9, 0.12);
    border: 1px solid rgba(212, 72, 9, 0.25);
    color: #fbbf24;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
    backdrop-filter: blur(8px);
  }

  .hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero__title {
    font-family: 'Playfair Display', serif !important;
    font-size: clamp(36px, 4.5vw, 64px) !important;
    font-weight: 700 !important;
    line-height: 1.15 !important;
    color: #fff !important;
    margin: 0 0 20px !important;
    padding: 0 !important;
    max-width: 600px;
    letter-spacing: -0.5px;
  }

  .hero__title :global(em) {
    font-style: normal;
    color: #fbbf24;
  }

  .hero__subtitle {
    font-size: clamp(15px, 1.6vw, 18px) !important;
    color: rgba(255, 255, 255, 0.7) !important;
    line-height: 1.7 !important;
    max-width: 500px;
    margin: 0 0 36px !important;
    padding: 0 !important;
  }

  .hero__cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 100px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 200ms ease;
    cursor: pointer;
    border: none;
  }

  .hero__cta--primary {
    background: linear-gradient(135deg, #d44809, #a43706);
    color: #fff;
    box-shadow: 0 4px 24px rgba(212, 72, 9, 0.4);
  }

  .hero__cta--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212, 72, 9, 0.5);
  }

  .hero__cta--ghost {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
  }

  .hero__cta--ghost:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.35);
  }

  /* Stats row */
  .hero__stats {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }

  .hero__stat-value {
    font-size: 32px;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .hero__stat-value--gold {
    color: #fbbf24;
  }

  .hero__stat-value--green {
    color: #4ade80;
  }

  .hero__stat-label {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 4px;
    line-height: 1.4;
  }

  .hero__stat-divider {
    width: 1px;
    background: rgba(255, 255, 255, 0.12);
    align-self: stretch;
  }

  /* ========== RIGHT COLUMN ========== */
  .hero__right {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .hero__featured {
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    transition: transform 200ms ease;
  }

  .hero__featured:hover {
    transform: translateY(-2px);
  }

  .hero__featured-tag {
    display: inline-block;
    background: rgba(212, 72, 9, 0.2);
    color: #fb923c;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: 12px;
  }

  .hero__featured-title {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 10px;
  }

  .hero__featured-excerpt {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .hero__featured-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #fbbf24;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
  }

  .hero__featured-link:hover {
    text-decoration: underline;
  }

  /* Mini area cards */
  .hero__areas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .hero__area-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 14px 16px;
    cursor: pointer;
    transition: all 200ms ease;
  }

  .hero__area-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .hero__area-card--active {
    border-color: rgba(212, 72, 9, 0.4);
    background: rgba(212, 72, 9, 0.08);
  }

  .hero__area-name {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 2px;
  }

  .hero__area-detail {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.4;
  }

  .hero__area-highlight {
    font-size: 11px;
    color: #fbbf24;
    font-weight: 600;
    margin-top: 4px;
  }

  /* Source attribution */
  .hero__source {
    position: absolute;
    bottom: 16px;
    right: clamp(1.5rem, 4vw, 3rem);
    z-index: 2;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.25);
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      padding-top: 100px;
    }
    .hero__right {
      display: none;
    }
    .hero__stats {
      gap: 24px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 90vh;
    }
    .hero__stats {
      gap: 16px;
    }
    .hero__stat-value {
      font-size: 24px;
    }
  }
</style>

<script type="module">
  const hero = document.querySelector('[data-hero]');
  const primaryCta = hero?.querySelector('[data-personalized-cta]');

  const intentMessages = {
    o_thuc: {
      cta: 'Nhận gợi ý khu vực ở thật'
    },
    dau_tu_trung_han: {
      cta: 'Nhận gợi ý đầu tư phù hợp'
    },
    kinh_doanh: {
      cta: 'Nhận gợi ý kinh doanh'
    }
  };

  const updateHero = (intent) => {
    if (!intent || !intentMessages[intent]) return;
    const copy = intentMessages[intent];
    if (primaryCta) {
      primaryCta.textContent = copy.cta;
    }
  };

  window.addEventListener('lead-intent-change', (event) => {
    const intent = event?.detail?.intent;
    updateHero(intent);
  });
</script>
