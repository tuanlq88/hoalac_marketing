---
import LeadForm from "@components/LeadForm.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const sectionClass = ['cta-module', className].filter(Boolean).join(' ');
---
<section class={sectionClass} data-cta-key="mofu">
  <LeadForm
    eyebrow="Gợi ý khu vực"
    headline="Nhận gợi ý khu vực phù hợp nhu cầu"
    description="Cho biết mục đích, ngân sách và mức chấp nhận pháp lý — nhận 2-3 khu vực phù hợp kèm lưu ý cần kiểm tra trước khi khảo sát thực địa."
    deferDisplay={false}
  />
</section>
