---
import LeadForm from "@components/LeadForm.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const sectionClass = ['cta-module', className].filter(Boolean).join(' ');
---
<section class={sectionClass} data-cta-key="tofu">
  <div class="inline-cta-header">
    <p class="inline-cta-header__title">Chia sẻ nhu cầu của anh/chị</p>
    <p class="inline-cta-header__desc">5 câu ngắn để chúng tôi gửi góc nhìn phù hợp.</p>
  </div>
  <LeadForm
    eyebrow=""
    headline=""
    description=""
    deferDisplay={false}
    showFloatingCta={false}
    placement="article_tofu"
  />
</section>

<style>
  .inline-cta-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 1.5rem;
  }
  .inline-cta-header__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.5rem;
  }
  .inline-cta-header__desc {
    color: #64748b;
    font-size: clamp(13px, 1.4vw, 15px);
    line-height: 1.6;
    margin: 0;
  }
</style>
