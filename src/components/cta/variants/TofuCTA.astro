---
import LeadForm from "@components/LeadForm.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const sectionClass = ['cta-module', className].filter(Boolean).join(' ');
---
<section class={sectionClass} data-cta-key="tofu">
  <LeadForm
    eyebrow="5 câu hỏi nhanh"
    headline="Kiểm tra mức phù hợp Hòa Lạc"
    description="Trả lời 5 câu ngắn — nhận gợi ý khu vực và lưu ý pháp lý phù hợp nhu cầu trong 24 giờ."
    deferDisplay={true}
  />
</section>
