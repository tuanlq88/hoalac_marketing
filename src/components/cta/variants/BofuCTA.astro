---
import LeadForm from "@components/LeadForm.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const sectionClass = ['cta-module', className].filter(Boolean).join(' ');
---
<section class={sectionClass} data-cta-key="bofu">
  <LeadForm
    eyebrow="Tư vấn chiến lược"
    headline="Nhận phân tích rủi ro và cơ hội trước khi quyết định"
    description="Chia sẻ nhu cầu cụ thể — nhận đánh giá pháp lý, vị trí và tiềm năng khu vực phù hợp trong 24 giờ."
    deferDisplay={false}
  />
</section>
