---
import LeadForm from "@components/LeadForm.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const sectionClass = ['cta-module', className].filter(Boolean).join(' ');
---
<section class={sectionClass} data-cta-key="bofu">
  <LeadForm
    eyebrow="Trao đổi riêng"
    headline="Chia sẻ nhu cầu cụ thể để nhận định hướng phù hợp"
    description="Pháp lý, vị trí, tiềm năng khu vực — phản hồi trong 24 giờ."
    deferDisplay={false}
    placement="article_bofu"
  />
</section>
