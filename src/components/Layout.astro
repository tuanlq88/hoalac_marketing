---
import "@styles/global.css";
import LeadForm from "@components/LeadForm.astro";
import tableScriptSrc from "../scripts/initTables.ts?url";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  publishedAt?: string;
  slug?: string;
}

const {
  title = "Tầm Nhìn Hòa Lạc",
  description = "Góc nhìn có hệ thống về quy hoạch, hạ tầng và thị trường Hòa Lạc — giúp nhà đầu tư tự đưa ra quyết định",
  image,
  publishedAt,
  slug,
} = Astro.props;

const baseEnv = import.meta.env.BASE_URL ?? '/';
const basePath = baseEnv.endsWith('/') ? baseEnv.slice(0, -1) : baseEnv;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).href : new URL('/images/og-default.jpg', Astro.site).href;
const homeHref = basePath || '/';
const blogHref = `${basePath}/blog`;
const pillarsHref = `${basePath}/pillars`;
---
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-88662KFZ9N"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-88662KFZ9N');
    </script>
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wxhnh70qb7");
    </script>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={publishedAt ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="Tầm Nhìn Hòa Lạc" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="robots" content="index, follow, noai, noimageai" />
    {publishedAt && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "image": ogImage,
        "datePublished": publishedAt,
        "url": canonicalURL,
        "publisher": {
          "@type": "Organization",
          "name": "Tầm Nhìn Hòa Lạc",
          "url": "https://www.tamnhinhoalac.vn"
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalURL
        }
      })} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href={homeHref} class="site-brand">
          <img src="/logo.png" alt="Tầm Nhìn Hòa Lạc" class="site-brand__logo" width="48" height="48" />
          <div class="site-brand__text">
            <span class="site-brand__title">Tầm Nhìn</span>
            <span class="site-brand__label">Hòa Lạc</span>
          </div>
        </a>
        <nav class="site-nav" aria-label="Điều hướng chính">
          <a href={blogHref} class="site-nav__pill site-nav__pill--accent">
            <span>Phân tích</span>
          </a>
          <a href="#lead-form" class="site-nav__pill site-nav__pill--cta" data-cta-variant="header_nav">
            <span>Tìm góc nhìn</span>
          </a>
        </nav>
        <button
          class="hamburger-btn"
          type="button"
          aria-label="Mo menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </div>
      <!-- Contact links moved to footer only -->

    </header>
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <div class="mobile-menu__backdrop"></div>
      <div class="mobile-menu__panel" role="dialog" aria-label="Menu chính">
        <div class="mobile-menu__header">
          <div class="mobile-menu__brand-group">
            <span class="mobile-menu__brand">Tầm Nhìn Hòa Lạc</span>
            <span class="mobile-menu__tagline">Quy hoạch & phân tích đầu tư</span>
          </div>
          <button class="mobile-menu__close" type="button" aria-label="Đóng menu">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
        <ul class="mobile-menu__nav">
          <li><a class="mobile-menu__link" href={homeHref}>
            <svg class="mobile-menu__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <div class="mobile-menu__link-text">
              <span>Trang chủ</span>
              <span class="mobile-menu__link-desc">Tổng quan thị trường Hòa Lạc</span>
            </div>
          </a></li>
          <li><a class="mobile-menu__link" href={blogHref}>
            <svg class="mobile-menu__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <div class="mobile-menu__link-text">
              <span>Phân tích</span>
              <span class="mobile-menu__link-desc">Pháp lý, quy hoạch, khu vực</span>
            </div>
          </a></li>
        </ul>
        <div class="mobile-menu__cta-section">
          <a class="mobile-menu__cta" href="#lead-form" data-cta-variant="mobile_menu">
            <svg class="mobile-menu__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div class="mobile-menu__link-text">
              <span>Tìm góc nhìn</span>
              <span class="mobile-menu__link-desc">Nhận phân tích miễn phí trong 24h</span>
            </div>
            <svg class="mobile-menu__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
        <div class="mobile-menu__trust">
          <div class="mobile-menu__trust-item">
            <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12 2.5 8.5" stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Dữ liệu từ các quyết định quy hoạch chính thức</span>
          </div>
          <div class="mobile-menu__trust-item">
            <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12 2.5 8.5" stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Phân tích khách quan, không môi giới</span>
          </div>
          <div class="mobile-menu__trust-item">
            <svg viewBox="0 0 16 16" fill="none"><path d="M13.5 4.5L6 12 2.5 8.5" stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Phản hồi trong 24 giờ làm việc</span>
          </div>
        </div>
        <div class="mobile-menu__meta">
          <p class="mobile-menu__meta-label">Liên hệ tư vấn</p>
          <a href="mailto:lienhe@insighthoalac.vn">
            <svg class="mobile-menu__meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            lienhe@insighthoalac.vn
          </a>
          <a href="https://t.me/insighthoalac" target="_blank" rel="noreferrer">
            <svg class="mobile-menu__meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.2 4.4L2.4 10.8c-.6.2-.6 1.1 0 1.3l4.5 1.7 1.7 5.4c.1.4.6.6 1 .3l2.4-2 4.2 3.1c.5.3 1.1 0 1.2-.5L21.8 5.3c.2-.7-.4-1.2-.6-.9z"/></svg>
            Telegram cập nhật
          </a>
        </div>
      </div>
    </div>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__quote-section">
        <p class="site-footer__quote-mark" aria-hidden="true">"</p>
        <p class="site-footer__quote">Đầu tư bất động sản không phải cuộc đua tốc độ — mà là cuộc chơi của người đọc được Thời, Thế, và Chiêu Thức.</p>
        <p class="site-footer__quote-attr">— Triết lý Tầm Nhìn Hòa Lạc</p>
      </div>
      <div class="site-footer__cta-strip">
        <div class="site-footer__cta-text">
          <strong>Cần một góc nhìn độc lập cho quyết định của bạn?</strong>
          <span>Phản hồi trong 24h. Không môi giới. Không spam.</span>
        </div>
        <div class="site-footer__cta-actions">
          <a href="#lead-form" class="site-footer__cta-primary" data-cta-variant="footer">Nhận phân tích →</a>
        </div>
      </div>
      <div class="site-footer__meta">
        <div class="site-footer__brand-mini">
          <strong>Tầm Nhìn Hòa Lạc</strong> · © {new Date().getFullYear()} · Nội dung mang tính tham khảo, không thay thế tư vấn pháp lý chuyên nghiệp.
        </div>
        <div class="site-footer__meta-nav">
          <a href={blogHref}>Phân tích</a>
        </div>
      </div>
    </footer>
    <LeadForm
      formId="lead-form-global"
      deferDisplay={true}
      showFloatingCta={false}
      isGlobalFallback={true}
    />
    <script type="module">
      // Hamburger menu
      const hamburgerBtn = document.querySelector('.hamburger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const backdrop = mobileMenu?.querySelector('.mobile-menu__backdrop');
      const panel = mobileMenu?.querySelector('.mobile-menu__panel');
      const closeBtn = mobileMenu?.querySelector('.mobile-menu__close');

      function openMenu() {
        if (!mobileMenu || !panel || !backdrop) return;
        mobileMenu.setAttribute('aria-hidden', 'false');
        hamburgerBtn?.setAttribute('aria-expanded', 'true');
        backdrop.classList.add('is-visible');
        panel.classList.add('is-open');
        document.body.classList.add('menu-open');
        closeBtn?.focus();
      }

      function closeMenu() {
        if (!mobileMenu || !panel || !backdrop) return;
        mobileMenu.setAttribute('aria-hidden', 'true');
        hamburgerBtn?.setAttribute('aria-expanded', 'false');
        backdrop.classList.remove('is-visible');
        panel.classList.remove('is-open');
        document.body.classList.remove('menu-open');
        hamburgerBtn?.focus();
      }

      hamburgerBtn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      backdrop?.addEventListener('click', closeMenu);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && panel?.classList.contains('is-open')) {
          closeMenu();
        }
      });

      mobileMenu?.querySelectorAll('.mobile-menu__link').forEach((link) => {
        link.addEventListener('click', closeMenu);
      });

      // Lazy load content images
      document.querySelectorAll('.reading-content img, .pillar-content img').forEach((img) => {
        if (!img.hasAttribute('loading')) {
          img.setAttribute('loading', 'lazy');
        }
        if (!img.hasAttribute('decoding')) {
          img.setAttribute('decoding', 'async');
        }
      });
    </script>
    <script type="module">
      const anchors = Array.from(document.querySelectorAll('a[href="#lead-form"]'));
      const portalQueueKey = '__hoaLacLeadPortalQueue__';
      window[portalQueueKey] = window[portalQueueKey] || [];

      const requestPortalOpen = () => {
        window.dispatchEvent(new CustomEvent('lead-form:request-open', {
          detail: { source: 'global-nav' }
        }));

        if (!window.__hoaLacLeadPortal?.open) {
          window[portalQueueKey].push('open');
        }
      };

      anchors.forEach((anchor) => {
        anchor.addEventListener('click', (event) => {
          const inlineForm = document.getElementById('lead-form');
          if (inlineForm) {
            return;
          }
          event.preventDefault();
          requestPortalOpen();
        });
      });

      // Footer CTA always visible — floating CTA auto-hides near footer via IntersectionObserver
    </script>
    <script type="module" src={tableScriptSrc}></script>
    <script>
      import { trackEvent } from '../lib/analytics/track';
      import { EVENTS } from '../lib/analytics/events';

      document.querySelectorAll('[data-cta-variant]').forEach((el) => {
        if (el.dataset.ctaTracked === 'true') return;
        el.dataset.ctaTracked = 'true';
        el.addEventListener('click', () => {
          trackEvent(EVENTS.CTA_CLICK, {
            cta_variant: el.getAttribute('data-cta-variant') ?? 'unknown',
            source_page: window.location.pathname,
          });
        });
      });
    </script>
  </body>
</html>
